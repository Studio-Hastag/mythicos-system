#!/usr/bin/python3

import sys
import os
import subprocess
import shlex
import shutil

# =========================
# 🎨 Couleurs ANSI
# =========================
ROUGE = "\033[91m"
VERT = "\033[92m"
JAUNE = "\033[93m"
BLEU = "\033[94m"
MAGENTA = "\033[95m"
CYAN = "\033[96m"
GRAS = "\033[1m"
RESET = "\033[0m"

# =========================
# 🏴 Bannière MythicOS
# =========================
def banniere():
    print(GRAS + CYAN + r"""
███╗   ███╗██╗   ██╗████████╗██╗  ██╗██╗ ██████╗ ██████╗ ███████╗
████╗ ████║╚██╗ ██╔╝╚══██╔══╝██║  ██║██║██╔════╝██╔═══██╗██╔════╝
██╔████╔██║ ╚████╔╝    ██║   ███████║██║██║     ██║   ██║███████╗
██║╚██╔╝██║  ╚██╔╝     ██║   ██╔══██║██║██║     ██║   ██║╚════██║
██║ ╚═╝ ██║   ██║      ██║   ██║  ██║██║╚██████╗╚██████╔╝███████║
╚═╝     ╚═╝   ╚═╝      ╚═╝   ╚═╝  ╚═╝╚═╝ ╚═════╝ ╚═════╝ ╚══════╝
""" + RESET)
    print(GRAS + VERT + "Gestionnaire de paquets MythicOS" + RESET)
    print(JAUNE + "Wrapper avancé pour APT\n" + RESET)

# =========================
# 📘 Aide complète
# =========================
def usage():
    banniere()
    print(GRAS + "Utilisation :" + RESET)
    print("  apt commande [options]")
    print("  apt help commande\n")
    print(GRAS + "Commandes disponibles :" + RESET)
    print("""
  add-repository   - Ajouter un dépôt
  autoclean        - Nettoyer le cache des paquets obsolètes
  autopurge        - Supprimer configs restantes des paquets supprimés
  autoremove       - Supprimer dépendances inutiles
  build            - Construire un paquet
  build-dep        - Installer dépendances de compilation
  changelog        - Voir journal des modifications
  check            - Vérifier dépendances cassées
  clean            - Nettoyer le cache téléchargé
  contains         - Trouver quel paquet contient un fichier
  content          - Lister fichiers d’un paquet
  deb              - Installer un .deb local
  depends          - Afficher dépendances
  dist-upgrade     - Mise à niveau complète
  download         - Télécharger un paquet
  edit-sources     - Modifier sources.list
  dselect-upgrade  - Appliquer sélections dselect
  full-upgrade     - Identique à dist-upgrade
  held             - Lister paquets bloqués
  help             - Aide sur commande
  hold             - Bloquer un paquet
  install          - Installer un paquet
  list             - Lister paquets
  policy           - Afficher politique versions
  purge            - Supprimer paquet + configuration
  recommends       - Voir paquets recommandés manquants
  rdepends         - Voir dépendances inverses
  reinstall        - Réinstaller un paquet
  remove           - Supprimer un paquet
  search           - Rechercher un paquet
  show             - Infos détaillées
  showhold         - Identique à held
  showsrc          - Infos paquet source
  source           - Télécharger sources
  unhold           - Débloquer un paquet
  update           - Mettre à jour liste paquets
  upgrade          - Mettre à jour paquets
  version          - Afficher version installée
""")
    sys.exit(1)

# =========================
# Alias
# =========================
aliases = {
    "dist-upgrade": "full-upgrade",
    "sources": "edit-sources",
    "held": "showhold"
}

# =========================
# Version
# =========================
if any(arg == "--version" for arg in sys.argv[1:]):
    try:
        version = subprocess.check_output(
            ["/usr/bin/apt", "--version"], text=True
        ).splitlines()[0]
        print(GRAS + version + RESET + " (MythicOS)")
    except Exception:
        print("apt (MythicOS) - version indisponible")
    sys.exit(0)

if len(sys.argv) < 2:
    usage()

argcommand = sys.argv[1]
argoptions = sys.argv[2:]

if argcommand in aliases:
    argcommand = aliases[argcommand]

# =========================
# Mapping commandes
# =========================
if argcommand in (
    "autoremove", "list", "show", "install", "remove",
    "purge", "update", "upgrade", "full-upgrade",
    "edit-sources", "showsrc", "autopurge"
):
    command = ["/usr/bin/apt", argcommand] + argoptions

elif argcommand in (
    "clean", "dselect-upgrade", "build-dep",
    "check", "autoclean", "source", "moo"
):
    command = ["apt-get", argcommand] + argoptions

elif argcommand in ("reinstall",):
    command = ["aptitude", argcommand] + argoptions

elif argcommand in ("stats", "depends", "rdepends", "policy"):
    command = ["apt-cache", argcommand] + argoptions

elif argcommand == "changelog":
    # MythicOS n'a pas de apt_changelog.py
    command = ["aptitude", argcommand] + argoptions

elif argcommand == "recommends":
    command = ["/usr/lib/mythicos/mythicos-system/mythicos-apt-recommends.py"] + argoptions

elif argcommand in ("showhold", "hold", "unhold"):
    command = ["apt-mark", argcommand] + argoptions

elif argcommand in ("markauto", "markmanual"):
    command = ["apt-mark", argcommand[4:]] + argoptions

elif argcommand == "contains":
    command = ["dpkg", "-S"] + argoptions

elif argcommand == "content":
    command = ["dpkg", "-L"] + argoptions

elif argcommand == "deb":
    command = ["dpkg", "-i"] + argoptions

elif argcommand == "build":
    command = ["dpkg-buildpackage"] + argoptions

elif argcommand == "version":
    try:
        version = subprocess.check_output(
            "dpkg-query -f '${Version}' -W %s 2>/dev/null"
            % shlex.quote(" ".join(argoptions)),
            shell=True
        ).decode("UTF-8")
        print(version)
    except:
        pass
    sys.exit(0)

elif argcommand == "download":
    command = ["/usr/lib/mythicos/mythicos-system/mythicos-apt-download.py"] + argoptions

elif argcommand == "add-repository":
    command = ["add-apt-repository"] + argoptions

elif argcommand == "search":
    columns = 80
    if sys.stdin.isatty():
        columns, rows = shutil.get_terminal_size(fallback=(80, 24))
    command = ["aptitude", "-w", str(columns), argcommand] + argoptions

else:
    usage()

# =========================
# Sudo automatique
# =========================
if os.getuid() != 0 and argcommand in (
    "autoremove", "install", "remove", "purge",
    "update", "upgrade", "full-upgrade",
    "edit-sources", "clean", "dselect-upgrade",
    "build-dep", "check", "autoclean",
    "reinstall", "deb", "hold", "unhold",
    "add-repository", "markauto", "markmanual",
    "autopurge"
):
    command = ["sudo"] + command

# =========================
# Exécution
# =========================
try:
    return_code = subprocess.call(command)
    sys.exit(return_code)
except KeyboardInterrupt:
    print("\n" + ROUGE + "Opération interrompue." + RESET)